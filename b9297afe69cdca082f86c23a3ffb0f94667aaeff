ams}`);\nconst swapTx = await signAndSendEvm(swap[0], wallet, provider);\nconsole.log(`Swap tx: ${swapTx.hash}`);\nawait swapTx.wait();\n```\n\n**Deps**: `npm install ethers`\n\n### Solana Swap (swap → sign \u0026 send)\n\n```typescript\nimport { Connection, Keypair } from '@solana/web3.js';\nimport bs58 from 'bs58';\n\nconst connection = new Connection('https://api.mainnet-beta.solana.com', 'confirmed');\nconst wallet = Keypair.fromSecretKey(bs58.decode(process.env.SOLANA_PRIVATE_KEY!));\n\n// 1. Get swap data — swap 1 SOL for BONK\nconst params = new URLSearchParams({\n  chainIndex: '501', fromTokenAddress: '11111111111111111111111111111111', // native SOL\n  toTokenAddress: 'DezXAZ8z7PnrnRJjz3wXBoRgixCa6xjnB7YaB1pPB263', // BONK\n  amount: '1000000000', slippagePercent: '1', userWalletAddress: wallet.publicKey.toBase58(),\n});\nconst swap = await okxFetch('GET', `/api/v6/dex/aggregator/swap?${params}`);\n\n// 2. Sign \u0026 send\nconst sig = await signAndSendSolana(swap[0], wallet, connection);\nconsole.log(`Swap tx: ${sig}`);\nawait waitForConfirmation(connection, sig);\n```\n\n**Deps**: `npm install @solana/web3.js bs58`\n\n## Sign \u0026 Send Helpers\n\n### EVM\n\n```javascript\nimport { ethers } from 'ethers';\n\nasync function signAndSendEvm(swapData, wallet, provider) {\n  const tx = swapData?.tx;\n  if (!tx) throw new Error('Swap response missing tx object');\n\n  const txRequest = {\n    to: tx.to,\n    data: tx.data,\n    value: ethers.toBigInt(tx.value || '0'),\n    gasLimit: ethers.toBigInt(tx.gas || tx.gasLimit || '0'),\n  };\n\n  if (tx.maxFeePerGas) {\n    txRequest.maxFeePerGas = ethers.toBigInt(tx.maxFeePerGas);\n    txRequest.maxPriorityFeePerGas = ethers.toBigInt(tx.maxPriorityFeePerGas || '0');\n  } else if (tx.gasPrice) {\n    txRequest.gasPrice = ethers.toBigInt(tx.gasPrice);\n  }\n\n  const signer = wallet.connect(provider);\n  return await signer.sendTransaction(txRequest);\n}\n```\n\n**Deps**: `npm install ethers`\n\n### Solana\n\n```javascript\nimport { Connection, Keypair, VersionedTransaction, Transaction } from '@solana/web3.js';\nimport bs58 from 'bs58';\n\nasync function signAndSendSolana(swapData, wallet, connection) {\n  const txData = swapData?.tx?.data || swapData?.txData || swapData?.callData;\n  let raw;\n  try { raw = bs58.decode(txData); } catch { raw = Buffer.from(txData, 'base64'); }\n\n  const { blockhash } = await connection.getLatestBlockhash('confirmed');\n  let sig;\n\n  try {\n    const tx = VersionedTransaction.deserialize(raw);\n    tx.message.recentBlockhash = blockhash;\n    tx.sign([wallet]);\n    sig = await connection.sendTransaction(tx, { maxRetries: 3, skipPreflight: false });\n  } catch {\n    const tx = Transaction.from(raw);\n    tx.recentBlockhash = blockhash;\n    tx.feePayer = wallet.publicKey;\n    tx.sign(wallet);\n    sig = await connection.sendRawTransaction(tx.serialize(), { maxRetries: 3, skipPreflight: false });\n  }\n  return sig;\n}\n\nasync function waitForConfirmation(connection, signature, timeoutMs = 60000) {\n  const start = Date.now();\n  while (Date.now() - start \u003c timeoutMs) {\n    const { value } = await connection.getSignatureStatuses([signature], { searchTransactionHistory: true });\n    const status = value?.[0];\n    if (status?.err) throw new Error(`Transaction failed: ${JSON.stringify(status.err)}`);\n    if (status?.confirmationStatus === 'confirmed' || status?.confirmationStatus === 'finalized') return;\n    await new Promise(r =\u003e setTimeout(r, 1200));\n  }\n  throw new Error(`Timed out after ${timeoutMs}ms waiting for ${signature}`);\n}\n```\n\n**Deps**: `npm install @solana/web3.js bs58`",
