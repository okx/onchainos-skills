{
  "description": "Check onchainos skill version drift when loading an okx-* skill",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-drift.sh\"",
            "timeout": 3,
            "async": false
          }
        ]
      }
    ]
  }
}
