{
  "meta": {
    "version": "2.1.0",
    "description": "Skill routing test: market, signal, token, trenches skills only",
    "providers": {
      "okx_focused": [
        "okx-dex-market",
        "okx-dex-signal",
        "okx-dex-token",
        "okx-dex-trenches"
      ]
    },
    "categories": {
      "clear_intent": "Unambiguous requests with obvious skill targets",
      "vague_intent": "Underspecified requests that still have a likely skill",
      "competitive": "Best-route or comparison queries",
      "brand": "Explicit DEX/platform name mentioned",
      "compound": "Multi-step or multi-skill workflows in a single prompt",
      "chain": "Chain-specific routing",
      "edge": "Typos, slang, mixed language, ultra-short",
      "adversarial": "Prompts designed to trick the router into firing the wrong skill",
      "pnl_routing": "PnL/win rate/trade history — must go to okx-dex-market, NOT okx-wallet-portfolio",
      "trenches": "Meme token discovery, dev reputation, bundle detection via okx-dex-trenches",
      "signals": "Smart money / whale / KOL signal tracking via okx-dex-signal",
      "token_deep_dive": "Token safety, traders, liquidity, hot tokens via okx-dex-token",
      "leaderboard": "Top trader rankings by PnL/win rate/volume — routes to okx-dex-signal (leaderboard subcommand)",
      "token_cluster": "Holder cluster concentration analysis, rug pull %, new wallet % — routes to okx-dex-token",
      "index_price": "Disambiguation: general price/行情 queries must use market price (not market index); market index only for explicit aggregate/index price requests",
      "address_tracker_activities": "Latest DEX activities for smart money, KOL, or custom tracked addresses — routes to okx-dex-market (address-tracker-activities subcommand)"
    }
  },
